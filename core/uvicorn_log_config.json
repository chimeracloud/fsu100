{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "default": {
      "()": "core.logging._CloudLoggingFormatter",
      "format": "%(asctime)s %(name)s %(levelname)s %(message)s",
      "rename_fields": {
        "asctime": "timestamp",
        "levelname": "level"
      }
    }
  },
  "handlers": {
    "default": {
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stdout",
      "formatter": "default"
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": ["default"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.error": {
      "handlers": ["default"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.access": {
      "handlers": ["default"],
      "level": "INFO",
      "propagate": false
    }
  },
  "root": {
    "handlers": ["default"],
    "level": "INFO"
  }
}
